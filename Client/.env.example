# Supabase — required for auth, database, and check-in data
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key

# Optional: Allowed origin for the Supabase edge function CORS allowlist
# Set this to your production frontend URL in the Supabase edge function env
ALLOWED_ORIGIN=https://your-frontend-domain.com

# NOTE: The OpenAI API key is handled server-side via the Supabase edge function.
# Do NOT add REACT_APP_OPENAI_API_KEY here — it would be exposed in the browser bundle.
# Set OPENAI_API_KEY in your Supabase edge function environment variables instead.
